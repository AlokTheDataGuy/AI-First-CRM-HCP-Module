# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# ---------------------------------------------------------------------------

# Get a free key at https://console.groq.com/keys  (REQUIRED for the AI to work)
GROQ_API_KEY=

# Model to drive the LangGraph tools.
# The assignment named gemma2-9b-it, but Groq DECOMMISSIONED that model on
# 2025-10-08 (it no longer serves requests). The assignment also permits
# llama-3.3-70b-versatile, which is active and far better at multi-tool calling,
# so that is the default here.
GROQ_MODEL=llama-3.3-70b-versatile

# Database connection.
# Default = zero-config SQLite so you can run instantly.
# Postgres example: postgresql+psycopg2://user:pass@localhost:5432/hcp_crm
# MySQL example:    mysql+pymysql://user:pass@localhost:3306/hcp_crm
DATABASE_URL=sqlite:///./hcp_crm.db

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
